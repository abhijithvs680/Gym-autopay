# Copy to .env and fill in. Used by docker compose for the Vite build (baked into static JS).
# Get values from Supabase: Project Settings → API.

VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: host port when using docker compose (default 8080)
# HOST_PORT=8080
